# Copy to .env for local development.

# YARBA portfolio content API (live resume/portfolio sections on mujakayadan.com)
VITE_YARBA_API_URL=https://api.yarba.app
VITE_YARBA_PORTFOLIO_TOKEN=pst_...

# YARBA chatbot — subdomain of your published YARBA site (muja.yarba.app → "muja").
# The React site can live on www.mujakayadan.com; chat still uses this subdomain.
VITE_YARBA_PORTFOLIO_SUBDOMAIN=muja
