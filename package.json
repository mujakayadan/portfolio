{
  "name": "muja-portfolio",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint:src": "eslint \"src/**/*.{ts,tsx,jsx}\" --max-warnings 0",
    "lint:vite": "eslint vite.config.ts vitest.config.ts",
    "lint": "npm run lint:src && npm run lint:vite",
    "lint:src:fix": "eslint \"src/**/*.{ts,tsx,jsx}\" --fix",
    "lint:vite:fix": "eslint vite.config.ts vitest.config.ts --fix",
    "lint:fix": "npm run lint:src:fix && npm run lint:vite:fix",
    "preview": "vite preview",
    "ts:check": "tsc --noEmit",
    "ts:watch": "tsc --noEmit --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,jsx,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "optimize:models": "node scripts/optimize-models.mjs",
    "validate": "npm run ts:check && npm run lint && npm run test && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "framer-motion": "^12.42.2",
    "maath": "^0.10.8",
    "react": "^19.2.7",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-vertical-timeline-component": "^4.0.0",
    "swiper": "^14.0.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@gltf-transform/cli": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/scope-manager": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "vite.config.ts": [
      "eslint --fix"
    ],
    "*.{css,md}": "prettier --write"
  }
}
